generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  role          String   @default("admin")
  created_at    DateTime @default(now())

  turism_spots TurismSpot[]
  pets         Pet[]
  courses      Course[]
  properties   Property[]
  dishes       Dish[]
  plans        Plan[]
  modalities   Modality[]
  events       Event[]
}

model TurismSpot {
  id              Int      @id @default(autoincrement())
  name            String
  description     String   @db.VarChar(200)
  district        String
  category        String
  latitude        Float
  longitude       Float
  requires_ticket Boolean  @default(false)
  created_by      Int
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  author User         @relation(fields: [created_by], references: [id])
  images TurismImage[]
}

model TurismImage {
  id       Int    @id @default(autoincrement())
  spot_id  Int
  file_url String

  spot TurismSpot @relation(fields: [spot_id], references: [id], onDelete: Cascade)
}

// ─── Atividade 1: Amigo Fiel — Portal de Adoção de Pets ─────────────────────

model Pet {
  id          Int      @id @default(autoincrement())
  name        String
  species     String
  age         Int
  size        String
  description String?  @db.Text
  status      String   @default("disponivel")
  created_by  Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  author User @relation(fields: [created_by], references: [id])
}

// ─── Atividade 2: EduTech — Catálogo de Cursos Online ────────────────────────

model Course {
  id          Int      @id @default(autoincrement())
  title       String
  instructor  String
  category    String
  workload    Int
  price       Float
  description String?  @db.Text
  created_by  Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  author User @relation(fields: [created_by], references: [id])
}

// ─── Atividade 3: EasyHome — Sistema de Imobiliária ─────────────────────────

model Property {
  id          Int      @id @default(autoincrement())
  type        String
  address     String
  area        Float
  price       Float
  modality    String
  description String?  @db.Text
  status      String   @default("disponivel")
  created_by  Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  author User @relation(fields: [created_by], references: [id])
}

// ─── Atividade 4: Chef's Menu — Cardápio Digital ─────────────────────────────

model Dish {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  price       Float
  description String?  @db.Text
  available   Boolean  @default(true)
  created_by  Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  author User @relation(fields: [created_by], references: [id])
}

// ─── Atividade 5: Fitness Hub — Gestão de Planos e Treinos ──────────────────

model Plan {
  id               Int      @id @default(autoincrement())
  name             String
  type             String
  price            Float
  weekly_frequency Int
  description      String   @db.Text
  created_by       Int
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  author User @relation(fields: [created_by], references: [id])
}

model Modality {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @db.Text
  level       String
  status      String   @default("ativa")
  created_by  Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  author User @relation(fields: [created_by], references: [id])
}

// ─── Atividade 6: Event-IT — Plataforma de Eventos ──────────────────────────

model Event {
  id               Int      @id @default(autoincrement())
  name             String
  category         String
  date_time        DateTime
  location         String
  description      String?  @db.Text
  max_capacity     Int
  registered_count Int      @default(0)
  created_by       Int
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  author User @relation(fields: [created_by], references: [id])
}
